# AgentHub WebSocket URL
# wrangler deploy 후 Cloudflare 대시보드에서 확인
AGENT_HUB_URL=wss://mgkh-otp-worker.<account>.workers.dev/agent-ws

# AgentHub 접속 인증 키
# 현재는 otp-worker의 SECRET_KEY 와 동일한 값을 사용 중
# (wrangler secret put AGENT_SECRET 으로 등록한 값)
AGENT_SECRET=your-secret-here

# Playwright 세션 파일 경로
# 세션 생성은 mgkh-auto-save/kakao_login.py 에서 수동 로그인 후 진행
# 생성된 파일을 session/kakao_state.json 으로 복사
SESSION_PATH=session/kakao_state.json

# Discord 웹훅 URL (에러 알림)
# Discord 채널 설정 > 연동 > 웹훅 에서 생성
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
