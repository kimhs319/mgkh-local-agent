# ───────────────────────────────────────────────
# mgkh-local-agent 환경변수 예시
# 상수값(URL, 경로)은 configs/config.py로 이동 → 여기서 제거
# 비밀값만 .env에 유지
# ───────────────────────────────────────────────

# AgentHub 접속 인증 키
AGENT_SECRET=your-secret-here

# Discord 웹훅 URL (에러 알림)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# mgkh-okchart-api 인증 비밀번호
OKCHART_APP_PASSWORD=your-okchart-password-here
