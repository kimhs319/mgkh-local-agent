# AgentHub WebSocket URL
# wrangler deploy 후 Cloudflare 대시보드에서 확인
AGENT_HUB_URL 항목 제거 (코드로 하드코딩)

# AgentHub 접속 인증 키
AGENT_SECRET=your-secret-here

# Discord 웹훉 URL (에러 알림)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# mgkh-okchart-api 연결 설정
# 상수값(URL)은 코드로 하드코딩, 비밀값만 .env 유지
OKCHART_APP_PASSWORD=your-okchart-password-here

# Playwright 세션 파일 경로 항목 제거 (configs/config.py로 이동)
# PDF 출력 디렉토리 항목 제거 (configs/config.py로 이동)
